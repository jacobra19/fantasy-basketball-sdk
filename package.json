{
  "name": "fantasy-basketball-sdk",
  "version": "0.0.0",
  "description": "Tree-shakeable fantasy basketball API SDK for ESPN, Yahoo, Fantrax, and more",
  "type": "module",
  "sideEffects": false,
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./espn": {
      "types": "./dist/espn/index.d.ts",
      "import": "./dist/espn/index.js"
    },
    "./yahoo": {
      "types": "./dist/yahoo/index.d.ts",
      "import": "./dist/yahoo/index.js"
    },
    "./fantrax": {
      "types": "./dist/fantrax/index.d.ts",
      "import": "./dist/fantrax/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.src.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "verify": "publint && node scripts/verify-dist.mjs",
    "prepublishOnly": "npm run build && npm run verify"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "publint": "^0.3.12",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^8.0.0",
    "vitest": "^3.2.3"
  }
}
